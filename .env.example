# ─────────────────────────────────────────
# ReimburseIQ Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change this to a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Anthropic API Key (for OCR receipt scanning)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Exchange Rate API (free tier available)
# Get key from: https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Data storage path (uses JSON file storage by default)
DATA_DIR=./data

